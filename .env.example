# MCP server — copiar a .env y cambiar valores
# BRIDGE_TOKEN debe coincidir exactamente con el token del AddOn (ambos lo leen de aquí).

BRIDGE_URL=http://127.0.0.1:8731
BRIDGE_TOKEN=CHANGE_ME_LOCAL_TOKEN

# ── AddOn NT8 (ApexBridgeAddOn.cs) — lee estas como variables de entorno del SO ──
# NT8 hereda el entorno del usuario. En Sim los defaults bastan (Sim101 / NQ).
# Al conectar Apex, exporta el nombre real de la cuenta y deja el símbolo en NQ.
#   Windows (PowerShell, persistente):  setx APEX_ACCOUNT "APEX-XXXXX"
#                                       setx APEX_INSTRUMENT "NQ"
#                                       setx BRIDGE_TOKEN "<token-secreto>"
# (reinicia NinjaTrader tras setx para que tome el entorno nuevo)
APEX_ACCOUNT=Sim101
APEX_INSTRUMENT=NQ

# ── Alertas Telegram (TelegramAlerts.cs) — Stream C ──────────────────────────
# Obtener token: crear bot en @BotFather → /newbot
# Obtener chat id: mandar /start al bot, luego:
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
#   El campo "chat.id" del primer mensaje es el chat id.
#   Windows (PowerShell, persistente):  setx TELEGRAM_BOT_TOKEN "123456:ABCdef..."
#                                       setx TELEGRAM_CHAT_ID   "987654321"
# (reinicia NinjaTrader tras setx)
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME
